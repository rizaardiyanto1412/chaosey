{
  "name": "wasd-web-game",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@wasd/shared && npm run build --workspace=@wasd/server",
    "compact-map": "node scripts/compact-spritefusion-map.js",
    "dev": "concurrently \"npm run dev -w @wasd/server\" \"npm run dev -w @wasd/client\"",
    "update-map": "bash scripts/update-reference-map.sh",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "npm run test -ws --if-present",
    "start": "npm run start --workspace=@wasd/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "canvas": "^3.2.3"
  }
}
